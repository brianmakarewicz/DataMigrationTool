{
  "type": "FBDI",
  "cred_role": "fin_impl",
  "auth_user": "fin_impl",
  "doc_account": "prc/purchaseOrder/import",
  "interface_details_id": 21,
  "import_job_name_raw": "/oracle/apps/ess/prc/po/pdoi;ImportSPOJob",
  "job_name": "/oracle/apps/ess/prc/po/pdoi,ImportSPOJob",
  "parameter_list": "300000046987012,300000047340498,SUBMIT,300000046987012,,N,,N,300000046987012_${PREFIX}",
  "filename": "PurchaseOrders_gold.zip",
  "csvs": [
    { "template": "PoHeadersInterfaceOrder.csv",         "fbdi_name": "PoHeadersInterfaceOrder.csv" },
    { "template": "PoLinesInterfaceOrder.csv",            "fbdi_name": "PoLinesInterfaceOrder.csv" },
    { "template": "PoLineLocationsInterfaceOrder.csv",    "fbdi_name": "PoLineLocationsInterfaceOrder.csv" },
    { "template": "PoDistributionsInterfaceOrder.csv",    "fbdi_name": "PoDistributionsInterfaceOrder.csv" }
  ],
  "downstream_jobs": [
    {
      "name": "ImportSPOJob (Import Orders)",
      "job_path": "/oracle/apps/ess/prc/po/pdoi,ImportSPOJob",
      "cred_role": "calvin.roth",
      "parameter_list": "300000046987012,300000047340498,SUBMIT,300000046987012,,N,,N,300000046987012_${PREFIX}"
    }
  ],
  "verify": {
    "cred_role": "fin_impl",
    "good_keys": ["${PREFIX}RT-PO-G1", "${PREFIX}RT-PO-G2"],
    "bad_keys": ["${PREFIX}RT-PO-BAD1"],
    "base_read": {
      "sql": "SELECT segment1 AS PO_NUMBER, po_header_id AS PO_HEADER_ID, document_status AS DOCUMENT_STATUS FROM po_headers_all WHERE segment1 LIKE :PREFIX || 'RT-PO-%'",
      "cols": ["PO_NUMBER", "PO_HEADER_ID", "DOCUMENT_STATUS"],
      "key_col": "PO_NUMBER",
      "id_col": "PO_HEADER_ID"
    },
    "interface_read": {
      "sql": "SELECT h.document_num AS PO_NUMBER, h.interface_header_id AS INTERFACE_HEADER_ID, h.process_code AS PROCESS_CODE, (SELECT LISTAGG(e.column_name || '=' || e.column_value || ': ' || e.error_message, ' | ') WITHIN GROUP (ORDER BY e.creation_date) FROM po_interface_errors e WHERE e.interface_header_id = h.interface_header_id) AS ERROR_MESSAGE FROM po_headers_interface h WHERE h.load_request_id = :LRID",
      "cols": ["PO_NUMBER", "INTERFACE_HEADER_ID", "PROCESS_CODE", "ERROR_MESSAGE"],
      "key_col": "PO_NUMBER",
      "error_col": "ERROR_MESSAGE"
    }
  }
}
